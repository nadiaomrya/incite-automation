---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <main class="page-content">
    <h1>What We Do: Our Specialties</h1>
    <p class="subtitle">Generating value is our focus. We grow your business's bottom line with</p>
    <ul>
      <li>Web design and development with automations and integrations</li>
      <li>Bespoke automation packages for
        <ul>
          <li>Lead generation</li>
          <li>Marketing</li>
          <li>Workflows</li>
          <li>Client intake, communication, and referrals</li>
          <li>Reputation management</li>
        </ul>
      </li>
    </ul>
  </main>
</Layout>

<style>
  .page-content {
    padding: 2rem;
    color: #eaeaea;
    max-width: 800px;
    margin: 2rem auto;
    background: rgba(17, 17, 17, 0.85);
    border-radius: 1rem;
  }
</style> 